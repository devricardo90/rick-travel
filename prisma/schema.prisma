generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  createdAt     DateTime  @default(now())
  emailVerified Boolean   @default(false)
  image         String?
  updatedAt     DateTime  @updatedAt
  role          UserRole  @default(USER)
  accounts      Account[]
  bookings      Booking[]
  sessions      Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Trip {
  id              String        @id @default(cuid())
  city            String
  priceCents      Int
  createdAt       DateTime      @default(now())
  endDate         DateTime?
  imageUrl        String        @default("/images/placeholder.svg")
  location        String?
  maxGuests       Int?
  startDate       DateTime?
  updatedAt       DateTime      @updatedAt
  title           Json
  description     Json?
  highlights      Json
  childrenAllowed Boolean       @default(true)
  durationDays    Int           @default(1)
  physicalLevel   PhysicalLevel @default(LIGHT)
  bookings        Booking[]
  schedules       TripSchedule[]
}

model TripSchedule {
  id                  String         @id @default(cuid())
  tripId              String
  startAt             DateTime
  endAt               DateTime?
  capacity            Int
  pricePerPersonCents Int
  status              String         @default("OPEN") // OPEN, CLOSED
  trip                Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  bookings            Booking[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([tripId, startAt])
}

model Booking {
  id              String         @id @default(cuid())
  userId          String
  tripId          String
  scheduleId      String?
  status          BookingStatus  @default(PENDING)
  paymentStatus   PaymentStatus  @default(UNPAID)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @default(now()) @updatedAt
  guestCount      Int            @default(1)
  totalPriceCents Int            @default(0)
  schedule        TripSchedule?  @relation(fields: [scheduleId], references: [id], onDelete: Restrict)
  trip            Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailLogs       EmailLog[]

  @@index([userId, createdAt])
  @@index([tripId])
  @@index([userId, tripId, scheduleId])
  @@index([status])
}

model EmailLog {
  id                String        @id @default(cuid())
  to                String
  template          EmailTemplate
  status            EmailStatus   @default(QUEUED)
  bookingId         String?
  booking           Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  providerMessageId String?
  error             String?
  createdAt         DateTime      @default(now())
  sentAt            DateTime?

  @@index([status, createdAt])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

enum PhysicalLevel {
  LIGHT
  MODERATE
  HARD
  EXTREME
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
}

enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  PARTIAL
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
}

enum EmailTemplate {
  BOOKING_CONFIRMED
  PAYMENT_CONFIRMED
}
