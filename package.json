{
  "name": "rick-travel",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "postinstall": "prisma generate",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check:env": "tsx scripts/validate-env.ts",
    "check:db": "tsx scripts/test-db.ts",
    "preflight:staging": "npm run check:env -- --target=staging && npm run check:db && npm run lint && npm run typecheck && npm run test && npm run build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "optimize-images": "node scripts/optimize-images.js"
  },
