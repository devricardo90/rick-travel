    "next-themes": "^0.4.0",
    "pg": "^8.18.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.1",
    "react-use-measure": "^2.1.7",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
