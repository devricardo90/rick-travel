# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ricktravel?schema=public"

# Auth
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"

# Email
RESEND_API_KEY="replace-with-resend-api-key"

# Mercado Pago
MP_ACCESS_TOKEN="replace-with-mercado-pago-access-token"
MP_WEBHOOK_SECRET="optional-webhook-signature-secret"

# E2E
E2E_ADMIN_EMAIL="e2e-admin@ricktravel.local"
E2E_ADMIN_PASSWORD="replace-with-e2e-admin-password"
E2E_USER_EMAIL="e2e-user@ricktravel.local"
E2E_USER_PASSWORD="replace-with-e2e-user-password"
