# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
.e2e-data.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/*.runtime.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# Kombai
.kombai/

# ─── Arquivos temporários de desenvolvimento ───
# Docs de planejamento local que não fazem parte do produto
ASSETS_NEEDED.md
**/ASSETS_NEEDED.md

# ─── Vídeos grandes (usar Git LFS ou CDN em produção) ───
# Mantenha apenas SVG/imagens otimizadas no repositório.
# Para vídeos, use storage externo (S3, Cloudflare R2, etc.)
# ou Git LFS: git lfs track "public/videos/*.mp4"
public/videos/*.mp4
public/videos/*.webm
public/videos/*.mov

# ─── Imagens brutas / não otimizadas ───
# Prefira manter apenas versões finais otimizadas (WebP, AVIF)
# Arquivos JPEG/PNG grandes devem ser comprimidos antes do commit
**/*.JPEG
